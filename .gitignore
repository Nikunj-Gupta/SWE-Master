# ===================================================================
# Venvs (each install_*_env.sh script rebuilds these from scratch)
# ===================================================================
.venv/
vllm_venv/
OpenRLHF_SFT/.venv/
OpenRLHF_SFT/OpenRLHF/.venv/
R2E-Gym/.venv/
**/.venv/

# OpenRLHF clone (install_sft_env.sh re-clones it)
OpenRLHF_SFT/OpenRLHF/

# ===================================================================
# Runtime artifacts (recreated by running the pipeline)
# ===================================================================

# All log directories (logs leak the wandb key on the deepspeed CLI!)
**/logs/
*.log

# SFT outputs
sft_smoke/
sft_real_data/
sft_real_data_29/
sft_final/

# Rollout outputs
rollout_smoke/results/
rollout_smoke/sft_data/

# vLLM PID files / runtime state
vllm.pid

# HF model cache (lives outside repo at /data/nikunj/hf_cache anyway,
# but ignore in case anyone clones into a place with hf_cache subdir)
hf_cache/

# DeepSpeed checkpoints (legacy paths)
ckpt/

# ===================================================================
# Secrets — never commit
# ===================================================================
*.token
*.key
.wandb_token
hf_token
secrets/
**/wandb/

# ===================================================================
# Python detritus
# ===================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
**/r2e_gym.egg-info/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# uv.lock is environment-specific in our setup (different machine = different lock)
uv.lock

# ===================================================================
# Jupyter
# ===================================================================
.ipynb_checkpoints
*-checkpoint.ipynb

# ===================================================================
# Editor / OS
# ===================================================================
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# ===================================================================
# Docker exports / large binaries
# ===================================================================
*.tar
*.tar.gz
*.tgz

# ===================================================================
# Don't accidentally ship trained model artifacts (multi-GB safetensors)
# ===================================================================
*.safetensors
*.bin
*.pt
*.pth
*.ckpt
