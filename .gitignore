# ===================================================================
# Venvs (each install_*_env.sh script rebuilds these from scratch)
# ===================================================================
.venv/
vllm_venv/
OpenRLHF_SFT/.venv/
OpenRLHF_SFT/OpenRLHF/.venv/
R2E-Gym/.venv/
**/.venv/

# OpenRLHF clone (install_sft_env.sh re-clones it)
OpenRLHF_SFT/OpenRLHF/

# ===================================================================
# Runtime artifacts (recreated by running the pipeline)
# ===================================================================

# All log directories (logs leak the wandb key on the deepspeed CLI!)
**/logs/
*.log

# SFT outputs
sft_smoke/
sft_real_data/
sft_real_data_29/
sft_final/
sft_pipeline/
sft_pipeline_planB_*/

# RL outputs (rl_smoke/logs is also covered by **/logs/, this catches extras)
rl_smoke/

# Hydra writes a per-cwd `outputs/` dir alongside ./outputs symlinks etc.
outputs/

# Rollout outputs
rollout_smoke/results/
rollout_smoke/sft_data/

# vLLM PID files / runtime state
vllm.pid

# HF model cache (lives outside repo at $SWE_MASTER_CACHE_ROOT/hf,
# but ignore in case anyone clones into a place with hf_cache subdir)
hf_cache/

# Local cache dir env.sh defaults to (when SWE_MASTER_CACHE_ROOT unset
# and /data is not writable, it falls back to <repo>/cache)
cache/

# DeepSpeed checkpoints (legacy paths)
ckpt/

# ===================================================================
# rLLM (DeepSWE) build artifacts — install_rl_env.sh rebuilds these
# ===================================================================
# verl is cloned fresh by install_rl_env.sh from agentica-project/verl
DeepSWE_RL/rllm/verl/
# Parquets generated by examples/swe/prepare_swe_data.py (~7 GB)
DeepSWE_RL/rllm/rllm/data/datasets/
# Dataset registry written by prepare_swe_data.py at runtime
DeepSWE_RL/rllm/rllm/registry/
# Tensorboard event files
DeepSWE_RL/rllm/rllm/tensorboard_log/
# rLLM trainer per-experiment dirs
DeepSWE_RL/rllm/rllm/train_output/
DeepSWE_RL/rllm/rllm/train_output_rollout/

# ===================================================================
# Large datasets (HF download targets) — recreated by
# data_preparation/download_swe_datasets.sh / r2egym_add_instance_id.py
# ===================================================================
datasets/
R2E-Gym-Subset/
R2E-Gym-Lite/
R2E-Gym-V1/
SWE-Bench-Verified/
SWE-Bench-Lite/
SWE-Gym/
SWE-rebench/
SWE-smith/
SweSmith-RL-Dataset/

# ===================================================================
# Secrets — never commit
# ===================================================================
*.token
*.key
.wandb_token
hf_token
secrets/
**/wandb/

# ===================================================================
# Python detritus
# ===================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
**/r2e_gym.egg-info/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# uv.lock is environment-specific in our setup (different machine = different lock)
uv.lock

# ===================================================================
# Jupyter
# ===================================================================
.ipynb_checkpoints
*-checkpoint.ipynb

# ===================================================================
# Editor / OS
# ===================================================================
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# ===================================================================
# Docker exports / large binaries
# ===================================================================
*.tar
*.tar.gz
*.tgz

# ===================================================================
# Don't accidentally ship trained model artifacts (multi-GB safetensors)
# ===================================================================
*.safetensors
*.bin
*.pt
*.pth
*.ckpt
